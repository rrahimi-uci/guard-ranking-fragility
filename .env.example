# Copy to research/.env (repo-level, OUTSIDE the portable notebooks/ folder) and fill in keys.
# Prefer this over notebooks/.env: the notebook README suggests zipping notebooks/ to share it, and a
# gitignored secret file still travels inside a zip. (Scripts load notebooks/.env first if present, then .env.)
# Both are optional: the pipeline runs a smoke/full path without them; keys only
# enable the gpt-5.4-mini baseline (OPENAI) and gated model downloads (HF).
OPENAI_API_KEY=
HF_TOKEN=
